generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum ConversationType {
  direct
  group
}

enum MessageType {
  text
  image
  file
  audio
  video
}

enum CallType {
  audio
  video
}

enum CallStatus {
  ongoing
  ended
  missed
  rejected
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String   @unique
  fullName  String
  password  String
  avatar    String?
  bio       String?
  status    String   @default("offline")
  conversations ConversationParticipant[]
  sentMessages Message[]
  blockedUsers Block[] @relation("IBlocked")
  blockedBy Block[] @relation("BlockedMe")
  lastSeen DateTime @default(now())
  callsInitiated Call[] @relation("CallsInitiated")
  callsParticipations CallParticipant[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ConversationDeletedFor ConversationDeletedFor[]

  @@map("users")
}

model Conversation {
  id            String   @id @default(cuid())
  type          ConversationType
  name          String?
  avatar        String?
  description   String?
  createdBy     String
  participants   ConversationParticipant[]
  messages       Message[]
  Calls          Call[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  conversationDeletedFor ConversationDeletedFor[]

  @@map("conversations")
}

model ConversationParticipant {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  role           String   @default("member")
  joinedAt       DateTime @default(now())
  lastReadAt     DateTime? 
  conversation    Conversation @relation(fields: [conversationId], references: [id])
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String   @id @default(cuid())
  tempId         String?  @unique
  conversationId String
  senderId       String
  content        String   @db.Text
  type           MessageType  @default(text) 
  fileUrl        String?
  fileName       String?
  fileSize       Int?
  replyToId      String?
  editedAt        DateTime?
  deletedAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  conversation    Conversation @relation(fields: [conversationId], references: [id])
  sender           User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  replyTo          Message?      @relation("MessageReplies", fields: [replyToId], references: [id])
  replies          Message[]     @relation("MessageReplies")
  deliveries       MessageDelivery[]
  reactions        Reaction[]
  deletedFor       MessageDeletedFor[]

  @@index([conversationId])
  @@index([senderId])
  @@map("messages")
}

model MessageDeletedFor{
  id String @id @default(cuid())
  messageId String
  userId String
  createdAt DateTime @default(now())
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId,userId])
  @@map("message_deleted_for")
}

model ConversationDeletedFor{
  id String @id @default(cuid())
  conversationId String
  userId String
  clearedAt DateTime @default(now())
  createdAt DateTime @default(now())
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId,userId])
  @@map("conversation_deleted_for")
}

model MessageDelivery{
  id String @id @default(cuid())
  messageId String
  userId String
  deliveredAt DateTime @default(now())
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  @@unique([messageId,userId])
  @@map("message_deliveries")
}

model Reaction {
  id         String   @id @default(cuid())
  messageId  String
  userId     String
  emoji      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  message    Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@map("reactions")
}

model Block {
  id         String   @id @default(cuid())
  blockerId   String
  blockedId   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  blocker    User      @relation("IBlocked", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked    User      @relation("BlockedMe", fields: [blockedId], references: [id], onDelete: Cascade)

  @@unique([blockerId, blockedId])
  @@map("blocks")
}

model Call{
  id String @id @default(cuid())
  conversationId String
  initiatorId String
  type CallType
  status CallStatus @default(ongoing)
  startedAt DateTime @default(now())
  endedAt DateTime?
  duration Int?
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  Initiator User @relation("CallsInitiated",fields: [initiatorId], references: [id], onDelete: Cascade)
  participants CallParticipant[]

  @@index([conversationId])
  @@index([initiatorId])
  @@map("calls")
}

model CallParticipant{
  id String @id @default(cuid())
  callId String
  userId String
  joinedAt DateTime @default(now())
  leftAt DateTime?
  call Call @relation(fields: [callId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([callId,userId])
  @@map("call_participants")
}